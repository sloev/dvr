# pi-gen build config for the DVR appliance image.
# Bookworm armhf (32-bit) — runs on Pi 2B and 3B.
# Sourced by pi-gen. Edit FIRST_USER_PASS before a real build.

IMG_NAME='dvr'
RELEASE='bookworm'

# Stages: 0 (bootstrap) 1 (truly minimal) 2 (Lite) + our appliance stage.
# No desktop stages → small, fast image.
STAGE_LIST='stage0 stage1 stage2 stage-dvr'

# Identity / access
TARGET_HOSTNAME='dvr'
FIRST_USER_NAME='pi'
FIRST_USER_PASS='dvr'              # CHANGE ME (or set PUBKEY_SSH_FIRST_USER)
DISABLE_FIRST_BOOT_USER_RENAME=1
ENABLE_SSH=1

# Locale / region — adjust to taste
LOCALE_DEFAULT='en_US.UTF-8'
KEYBOARD_KEYMAP='us'
KEYBOARD_LAYOUT='English (US)'
TIMEZONE_DEFAULT='Europe/Oslo'
WPA_COUNTRY='NO'

# Compress the exported image
DEPLOY_COMPRESSION='xz'
COMPRESSION_LEVEL=6
