export component AppWindow inherits Window {
    width: 1920px;
    height: 1080px;
    background: transparent; // For KMS/DRM

    in property <bool> is-recording: false;
    in property <bool> is-stopmotion-mode: false;
    in property <int> stopmotion-frame-count: 0;
    in property <string> disk-usage: "0%";
    in property <string> ram-usage: "0%";
    in property <string> cpu-load: "0%";
    in property <string> fps-text: "30 FPS";
    in property <string> recording-time: "00:00:00";
    in property <string> notification-text: "";
    in property <float> audio-level: 0.0; // 0.0 to 1.0

    in property <bool> is-wifi-mode: false;
    in property <bool> is-settings-mode: false;
    in property <string> wifi-ssid: "";
    in property <string> wifi-password: "";

    callback record-clicked();
    callback stop-clicked();
    callback gallery-clicked();
    callback capture-still-clicked();
    callback add-marker-clicked();
    callback format-usb-clicked();
    callback eject-usb-clicked();
    callback shutdown-clicked();
    callback toggle-stopmotion-clicked();
    callback stopmotion-capture-clicked();
    callback stopmotion-compile-clicked();
    callback play-video-clicked();
    callback wifi-settings-clicked();
    callback connect-wifi-clicked();
    callback capture-settings-clicked();
    callback apply-settings-clicked();

    // Top Dashboard
    Rectangle {
        y: 20px;
        x: 20px;
        width: 1880px;
        height: 80px;
        background: #00000080;
        border-radius: 10px;

        HorizontalLayout {
            padding: 20px;
            alignment: space-between;

            HorizontalLayout {
                spacing: 20px;
                Rectangle {
                    width: 40px;
                    height: 40px;
                    border-radius: 20px;
                    background: is-recording ? red : gray;
                }
                Text {
                    text: is-stopmotion-mode ? "STOPMOTION: " + stopmotion-frame-count + " frames" : (is-recording ? "REC " + recording-time : "READY");
                    color: white;
                    font-size: 32px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
                if notification-text != "": Text {
                    text: notification-text;
                    color: #00ff00;
                    font-size: 28px;
                    vertical-alignment: center;
                }
            }

            HorizontalLayout {
                spacing: 40px;
                // Audio Meter
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "MIC:"; color: white; font-size: 24px; vertical-alignment: center; }
                    Rectangle {
                        width: 150px;
                        height: 30px;
                        background: #333;
                        border-radius: 5px;
                        Rectangle {
                            width: 150px * audio-level;
                            height: 30px;
                            background: audio-level > 0.8 ? red : (audio-level > 0.5 ? yellow : green);
                            border-radius: 5px;
                        }
                    }
                }
                Text { text: "CPU: " + cpu-load; color: white; font-size: 24px; vertical-alignment: center; }
                Text { text: "RAM: " + ram-usage; color: white; font-size: 24px; vertical-alignment: center; }
                Text { text: "DISK: " + disk-usage; color: white; font-size: 24px; vertical-alignment: center; }
                Text { text: fps-text; color: white; font-size: 24px; vertical-alignment: center; }
            }
        }
    }

    if !is-stopmotion-mode: Rectangle {
        y: 120px;
        x: 20px;
        width: 250px;
        height: 400px;
        background: transparent;
        
        VerticalLayout {
            spacing: 20px;
            
            Rectangle {
                height: 80px; background: #444; border-radius: 40px;
                Text { text: "🎬 Stopmotion"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.toggle-stopmotion-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #444; border-radius: 40px;
                Text { text: "▶ Play Video"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.play-video-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #444; border-radius: 40px;
                Text { text: "📶 Wi-Fi Client"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.wifi-settings-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #444; border-radius: 40px;
                Text { text: "⚙ Settings"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.capture-settings-clicked(); } }
            }
        }
    }

    if is-stopmotion-mode: Rectangle {
        y: 120px;
        x: 20px;
        width: 250px;
        height: 400px;
        background: transparent;
        
        VerticalLayout {
            spacing: 20px;
            
            Rectangle {
                height: 80px; background: #ff3333; border-radius: 40px;
                Text { text: "Exit Stopmo"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.toggle-stopmotion-clicked(); } }
            }
        }
    }

    if is-settings-mode: Rectangle {
        y: 120px;
        x: 300px;
        width: 600px;
        height: 400px;
        background: #333333f0;
        border-radius: 20px;
        
        VerticalLayout {
            padding: 20px;
            spacing: 20px;
            
            Text { text: "Capture Settings"; color: white; font-size: 32px; horizontal-alignment: center; }
            
            Text { text: "Resolution: 1920x1080 -> 1280x720"; color: white; font-size: 24px; }
            
            Rectangle {
                height: 80px; background: #555; border-radius: 20px;
                Text { text: "Apply (Restart Required)"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.apply-settings-clicked(); } }
            }
            
            Rectangle {
                height: 80px; background: #ff3333; border-radius: 20px;
                Text { text: "Cancel"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.capture-settings-clicked(); } }
            }
        }
    }

    if is-wifi-mode: Rectangle {
        y: 120px;
        x: 300px;
        width: 600px;
        height: 400px;
        background: #333333f0;
        border-radius: 20px;
        
        VerticalLayout {
            padding: 20px;
            spacing: 20px;
            
            Text { text: "Wi-Fi Settings"; color: white; font-size: 32px; horizontal-alignment: center; }
            
            Text { text: "SSID: (Hardcoded for demo)"; color: white; font-size: 24px; }
            
            Rectangle {
                height: 80px; background: #555; border-radius: 20px;
                Text { text: "Connect to Network"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.connect-wifi-clicked(); } }
            }
            
            Rectangle {
                height: 80px; background: #ff3333; border-radius: 20px;
                Text { text: "Cancel"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.wifi-settings-clicked(); } }
            }
        }
    }


    // Right Controls (Quick Actions)
    if !is-stopmotion-mode: Rectangle {
        y: 120px;
        x: 1700px;
        width: 200px;
        height: 400px;
        background: transparent;
        
        VerticalLayout {
            spacing: 20px;
            
            Rectangle {
                height: 80px; background: #555; border-radius: 40px;
                Text { text: "📷 Still"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.capture-still-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #555; border-radius: 40px;
                Text { text: "⊕ Marker"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.add-marker-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #800000; border-radius: 40px;
                Text { text: "Format USB"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.format-usb-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #888; border-radius: 40px;
                Text { text: "⏏ Eject"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.eject-usb-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #ff3333; border-radius: 40px;
                Text { text: "⏻ Power"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.shutdown-clicked(); } }
            }
        }
    }

    // Bottom Controls
    if !is-stopmotion-mode: Rectangle {
        y: 920px;
        x: 20px;
        width: 1880px;
        height: 140px;
        background: transparent;

        HorizontalLayout {
            alignment: center;
            spacing: 60px;

            Rectangle {
                width: 200px;
                height: 100px;
                background: is-recording ? gray : #ff3333;
                border-radius: 50px;
                Text { text: "Record"; color: white; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.record-clicked(); } }
            }

            Rectangle {
                width: 200px;
                height: 100px;
                background: !is-recording ? gray : #ff9900;
                border-radius: 50px;
                Text { text: "Stop"; color: white; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.stop-clicked(); } }
            }

            Rectangle {
                width: 200px;
                height: 100px;
                background: #3399ff;
                border-radius: 50px;
                Text { text: "Gallery"; color: white; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.gallery-clicked(); } }
            }
        }
    }

    // Stopmotion Bottom Controls
    if is-stopmotion-mode: Rectangle {
        y: 920px;
        x: 20px;
        width: 1880px;
        height: 140px;
        background: transparent;

        HorizontalLayout {
            alignment: center;
            spacing: 60px;

            Rectangle {
                width: 300px;
                height: 100px;
                background: #ff9900;
                border-radius: 50px;
                Text { text: "Capture Frame"; color: white; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.stopmotion-capture-clicked(); } }
            }

            Rectangle {
                width: 300px;
                height: 100px;
                background: #3399ff;
                border-radius: 50px;
                Text { text: "Compile Video"; color: white; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.stopmotion-compile-clicked(); } }
            }
        }
    }
}
