export component AppWindow inherits Window {
    width: 1920px;
    height: 1080px;
    background: transparent; // For KMS/DRM to show underneath

    in property <bool> is-recording: false;
    in property <string> disk-usage: "0%";
    in property <string> ram-usage: "0%";
    in property <string> cpu-load: "0%";
    in property <string> fps-text: "0 FPS";
    in property <string> recording-time: "00:00:00";

    callback record-clicked();
    callback stop-clicked();
    callback gallery-clicked();

    // Top Dashboard
    Rectangle {
        y: 20px;
        x: 20px;
        width: 1880px;
        height: 80px;
        background: #00000080;
        border-radius: 10px;

        HorizontalLayout {
            padding: 20px;
            alignment: space-between;

            HorizontalLayout {
                spacing: 20px;
                // Recording Indicator
                Rectangle {
                    width: 40px;
                    height: 40px;
                    border-radius: 20px;
                    background: is-recording ? red : gray;
                }
                Text {
                    text: is-recording ? "REC " + recording-time : "READY";
                    color: white;
                    font-size: 32px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
            }

            HorizontalLayout {
                spacing: 40px;
                Text { text: "CPU: " + cpu-load; color: white; font-size: 24px; vertical-alignment: center; }
                Text { text: "RAM: " + ram-usage; color: white; font-size: 24px; vertical-alignment: center; }
                Text { text: "DISK: " + disk-usage; color: white; font-size: 24px; vertical-alignment: center; }
                Text { text: fps-text; color: white; font-size: 24px; vertical-alignment: center; }
            }
        }
    }

    // Bottom Controls
    Rectangle {
        y: 920px;
        x: 20px;
        width: 1880px;
        height: 140px;
        background: transparent;

        HorizontalLayout {
            alignment: center;
            spacing: 60px;

            Rectangle {
                width: 200px;
                height: 100px;
                background: is-recording ? gray : #ff3333;
                border-radius: 50px;
                Text {
                    text: "Record";
                    color: white;
                    font-size: 32px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea { clicked => { root.record-clicked(); } }
            }

            Rectangle {
                width: 200px;
                height: 100px;
                background: !is-recording ? gray : #ff9900;
                border-radius: 50px;
                Text {
                    text: "Stop";
                    color: white;
                    font-size: 32px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea { clicked => { root.stop-clicked(); } }
            }

            Rectangle {
                width: 200px;
                height: 100px;
                background: #3399ff;
                border-radius: 50px;
                Text {
                    text: "Gallery";
                    color: white;
                    font-size: 32px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea { clicked => { root.gallery-clicked(); } }
            }
        }
    }
}
