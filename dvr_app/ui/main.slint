import { LineEdit, ScrollView, ListView } from "std-widgets.slint";

export struct VideoItem {
    image_path: image,
    filename: string,
    path: string,
}

export component AppWindow inherits Window {
    width: 1920px;
    height: 1080px;
    background: transparent; // For KMS/DRM

    in property <bool> is-recording: false;
    in property <bool> is-stopmotion-mode: false;
    in property <int> stopmotion-frame-count: 0;
    in property <string> disk-usage: "0%";
    in property <string> ram-usage: "0%";
    in property <string> cpu-load: "0%";
    in property <string> fps-text: "30 FPS";
    in property <string> recording-time: "00:00:00";
    in property <string> notification-text: "";
    in property <float> audio-level: 0.0; // 0.0 to 1.0

    in property <bool> is-wifi-mode: false;
    in property <bool> is-settings-mode: false;
    in property <bool> is-gallery-mode: false;
    out property <string> wifi-ssid: "";
    out property <string> wifi-password: "";
    in property <[VideoItem]> video-items: [];

    callback record-clicked();
    callback stop-clicked();
    callback gallery-clicked();
    callback capture-still-clicked();
    callback add-marker-clicked();
    callback format-usb-clicked();
    callback eject-usb-clicked();
    callback shutdown-clicked();
    callback toggle-stopmotion-clicked();
    callback stopmotion-capture-clicked();
    callback stopmotion-compile-clicked();
    callback play-video-clicked(string);
    callback wifi-settings-clicked();
    callback connect-wifi-clicked();
    callback capture-settings-clicked();
    callback apply-settings-clicked();

    // Top Dashboard
    Rectangle {
        y: 20px;
        x: 20px;
        width: 1880px;
        height: 80px;
        background: #00000080;
        border-radius: 10px;
        border-width: 1px;
        border-color: #00ff00;

        HorizontalLayout {
            padding: 20px;
            alignment: space-between;

            HorizontalLayout {
                spacing: 20px;
                Rectangle {
                    width: 40px;
                    height: 40px;
                    border-radius: 20px;
                    background: is-recording ? red : gray;
                }
                Text {
                    text: is-stopmotion-mode ? "STOPMOTION: " + stopmotion-frame-count + " frames" : (is-recording ? "REC " + recording-time : "READY");
                    color: #00ff00;
                    font-size: 32px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
                if notification-text != "": Text {
                    text: notification-text;
                    color: #00ff00;
                    font-size: 28px;
                    vertical-alignment: center;
                }
            }

            HorizontalLayout {
                spacing: 40px;
                // Audio Meter
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "MIC:"; color: #00ff00; font-size: 24px; vertical-alignment: center; }
                    Rectangle {
                        width: 150px;
                        height: 30px;
                        background: #111;
                        border-radius: 5px;
                        Rectangle {
                            width: 150px * audio-level;
                            height: 30px;
                            background: audio-level > 0.8 ? red : (audio-level > 0.5 ? yellow : green);
                            border-radius: 5px;
                            animate width { duration: 100ms; easing: linear; }
                        }
                    }
                }
                Text { text: "CPU: " + cpu-load; color: #00ff00; font-size: 24px; vertical-alignment: center; }
                Text { text: "RAM: " + ram-usage; color: #00ff00; font-size: 24px; vertical-alignment: center; }
                Text { text: "DISK: " + disk-usage; color: #00ff00; font-size: 24px; vertical-alignment: center; }
                Text { text: fps-text; color: #00ff00; font-size: 24px; vertical-alignment: center; }
            }
        }
    }

    if !is-stopmotion-mode: Rectangle {
        y: 120px;
        x: 20px;
        width: 250px;
        height: 400px;
        background: transparent;
        
        VerticalLayout {
            spacing: 20px;
            
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "🎬 Stopmotion"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.toggle-stopmotion-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "📶 Wi-Fi Client"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.wifi-settings-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "⚙ Settings"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.capture-settings-clicked(); } }
            }
        }
    }

    if is-stopmotion-mode: Rectangle {
        y: 120px;
        x: 20px;
        width: 250px;
        height: 400px;
        background: transparent;
        
        VerticalLayout {
            spacing: 20px;
            
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #ff3333;
                Text { text: "Exit Stopmo"; color: #ff3333; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.toggle-stopmotion-clicked(); } }
            }
        }
    }

    Rectangle {
        y: is-gallery-mode ? 120px : -1000px;
        x: 300px;
        width: 1200px;
        height: 800px;
        background: #111111f0;
        border-radius: 20px;
        border-width: 2px;
        border-color: #00ff00;
        opacity: is-gallery-mode ? 1.0 : 0.0;
        animate y { duration: 300ms; easing: ease-in-out; }
        animate opacity { duration: 300ms; easing: ease-in-out; }

        VerticalLayout {
            padding: 20px;
            spacing: 20px;

            HorizontalLayout {
                Text { text: "Gallery"; color: #00ff00; font-size: 32px; }
                Rectangle {
                    width: 100px; height: 50px; background: #111; border-radius: 10px; border-width: 1px; border-color: #ff3333;
                    Text { text: "Close"; color: #ff3333; font-size: 20px; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { clicked => { root.gallery-clicked(); } }
                }
            }

            Rectangle {
                background: transparent;
                ScrollView {
                    height: 100%;
                    width: 100%;
                    HorizontalLayout {
                        spacing: 20px;
                        for item in root.video-items: Rectangle {
                            width: 320px;
                            height: 240px;
                            background: ta.pressed ? #333333 : #222222a0;
                            border-radius: 10px;
                            border-width: 2px;
                            border-color: #00ff00;

                            VerticalLayout {
                                padding: 10px;
                                spacing: 10px;

                                Image {
                                    source: item.image_path;
                                    width: 300px;
                                    height: 168px;
                                    image-fit: cover;
                                }

                                Text {
                                    text: item.filename;
                                    color: #00ff00;
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                }
                            }

                            ta := TouchArea {
                                clicked => {
                                    root.play-video-clicked(item.path);
                                    root.gallery-clicked();
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        y: is-settings-mode ? 120px : -500px;
        x: 300px;
        width: 600px;
        height: 400px;
        background: #111111f0;
        border-radius: 20px;
        border-width: 2px;
        border-color: #00ff00;
        opacity: is-settings-mode ? 1.0 : 0.0;
        animate y { duration: 300ms; easing: ease-in-out; }
        animate opacity { duration: 300ms; easing: ease-in-out; }
        
        VerticalLayout {
            padding: 20px;
            spacing: 20px;
            
            Text { text: "Capture Settings"; color: #00ff00; font-size: 32px; horizontal-alignment: center; }
            
            Text { text: "Resolution: 1920x1080 -> 1280x720"; color: #00ff00; font-size: 24px; }
            
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "Apply (Restart Required)"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.apply-settings-clicked(); } }
            }
            
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #ff3333;
                Text { text: "Cancel"; color: #ff3333; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.capture-settings-clicked(); } }
            }
        }
    }

    Rectangle {
        y: is-wifi-mode ? 120px : -500px;
        x: 300px;
        width: 600px;
        height: 400px;
        background: #111111f0;
        border-radius: 20px;
        border-width: 2px;
        border-color: #00ff00;
        opacity: is-wifi-mode ? 1.0 : 0.0;
        animate y { duration: 300ms; easing: ease-in-out; }
        animate opacity { duration: 300ms; easing: ease-in-out; }
        
        VerticalLayout {
            padding: 20px;
            spacing: 20px;
            
            Text { text: "Wi-Fi Settings"; color: #00ff00; font-size: 32px; horizontal-alignment: center; }
            
            HorizontalLayout {
                spacing: 10px;
                Text { text: "SSID:"; color: #00ff00; font-size: 24px; vertical-alignment: center; }
                LineEdit {
                    text: root.wifi-ssid;
                    font-size: 24px;
                    accepted => { root.wifi-ssid = self.text; }
                    edited => { root.wifi-ssid = self.text; }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Password:"; color: #00ff00; font-size: 24px; vertical-alignment: center; }
                LineEdit {
                    text: root.wifi-password;
                    font-size: 24px;
                    input-type: password;
                    accepted => { root.wifi-password = self.text; }
                    edited => { root.wifi-password = self.text; }
                }
            }
            
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "Connect to Network"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.connect-wifi-clicked(); } }
            }
            
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #ff3333;
                Text { text: "Cancel"; color: #ff3333; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.wifi-settings-clicked(); } }
            }
        }
    }


    // Right Controls (Quick Actions)
    if !is-stopmotion-mode: Rectangle {
        y: 120px;
        x: 1700px;
        width: 200px;
        height: 400px;
        background: transparent;
        
        VerticalLayout {
            spacing: 20px;
            
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "📷 Still"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.capture-still-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "⊕ Marker"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.add-marker-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "Format USB"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.format-usb-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #00ff00;
                Text { text: "⏏ Eject"; color: #00ff00; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.eject-usb-clicked(); } }
            }
            Rectangle {
                height: 80px; background: #111111a0; border-radius: 10px; border-width: 1px; border-color: #ff3333;
                Text { text: "⏻ Power"; color: #ff3333; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.shutdown-clicked(); } }
            }
        }
    }

    // Bottom Controls
    if !is-stopmotion-mode: Rectangle {
        y: 920px;
        x: 20px;
        width: 1880px;
        height: 140px;
        background: transparent;

        HorizontalLayout {
            alignment: center;
            spacing: 60px;

            Rectangle {
                width: 200px;
                height: 100px;
                background: is-recording ? gray : #111;
                border-radius: 10px;
                border-width: 2px; border-color: #ff3333;
                Text { text: "Record"; color: #ff3333; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.record-clicked(); } }
            }

            Rectangle {
                width: 200px;
                height: 100px;
                background: !is-recording ? gray : #111;
                border-radius: 10px;
                border-width: 2px; border-color: #ff9900;
                Text { text: "Stop"; color: #ff9900; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.stop-clicked(); } }
            }

            Rectangle {
                width: 200px;
                height: 100px;
                background: #111;
                border-radius: 10px;
                border-width: 2px; border-color: #3399ff;
                Text { text: "Gallery"; color: #3399ff; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.gallery-clicked(); } }
            }
        }
    }

    // Stopmotion Bottom Controls
    if is-stopmotion-mode: Rectangle {
        y: 920px;
        x: 20px;
        width: 1880px;
        height: 140px;
        background: transparent;

        HorizontalLayout {
            alignment: center;
            spacing: 60px;

            Rectangle {
                width: 300px;
                height: 100px;
                background: #111;
                border-radius: 10px;
                border-width: 2px; border-color: #ff9900;
                Text { text: "Capture Frame"; color: #ff9900; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.stopmotion-capture-clicked(); } }
            }

            Rectangle {
                width: 300px;
                height: 100px;
                background: #111;
                border-radius: 10px;
                border-width: 2px; border-color: #3399ff;
                Text { text: "Compile Video"; color: #3399ff; font-size: 32px; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { clicked => { root.stopmotion-compile-clicked(); } }
            }
        }
    }
}
